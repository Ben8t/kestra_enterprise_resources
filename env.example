# Database Configuration
POSTGRES_DB=kestra
POSTGRES_USER=kestra
POSTGRES_PASSWORD=your_postgres_password

# MotherDuck Token
MOTHERDUCK_TOKEN=your_motherduck_token

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key

# Keycloak OAuth2 client
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret

# Resend API Key
RESEND_API_KEY=your_resend_api_key

# Slack
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Kestra Configuration
KESTRA_ENCRYPTION_SECRET_KEY=your_encryption_secret_key
KESTRA_JDBC_SECRET=your_jdbc_secret
KESTRA_WORKER_REGISTRATION_TOKEN=your_worker_registration_token

# License Configuration
KESTRA_LICENSE_ID=your_license_id
KESTRA_LICENSE_FINGERPRINT=your_license_fingerprint
KESTRA_LICENSE_KEY=your_license_key

# Existing Terraform variables
KESTRA_USER=your_kestra_user_email
KESTRA_PASSWORD=your_kestra_password
QA_USER_PASSWORD=your_qa_user_password
GITHUB_TOKEN=your_github_token
KESTRA_BASE_URL=http://host.docker.internal:8080/api/v1
KESTRA_TENANT_ID=main
KESTRA_USERNAME=your_kestra_username

# AWS Configuration
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=your_aws_region
AWS_S3_BUCKET=your_aws_s3_bucket
